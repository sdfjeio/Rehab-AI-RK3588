# ======================================
# 1. PyCharm / IDE 专属配置（必须忽略！）
# ======================================
.idea/               # PyCharm 核心配置文件夹（每个人电脑不同，绝对不上传）
*.iml                # PyCharm 模块配置文件
*.iws
*.ipr
workspace.xml        # 个人工作区配置
tasks.xml
usage-statistics.xml

# ======================================
# 2. Python 项目通用忽略（必加）
# ======================================
# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境（venv/conda 都忽略）
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# 日志文件
*.log
logs/

# ======================================
# 3. 项目构建 / 打包文件
# ======================================
dist/
build/
*.egg-info/
*.egg
*.whl
pip-wheel-metadata/

# ======================================
# 4. 敏感文件（密码、密钥、环境变量）
# ======================================
.env                 # 数据库密码、API 密钥（绝对不能上传！）
.env.local
.env.production
secrets.json
config.ini

# ======================================
# 5. 系统垃圾文件（所有电脑通用）
# ======================================
# Mac 系统
.DS_Store
.DS_Store?
._*

# Windows 系统
Thumbs.db
ehthumbs.db
desktop.ini

# 临时文件
*.tmp
*.temp

# ======================================
# 6. Claude Code 本地配置
# ======================================
.claude/
*.claude/

# ======================================
# 7. 本地构建目录
# ======================================
build_desktop/
rknn_model_zoo-main/